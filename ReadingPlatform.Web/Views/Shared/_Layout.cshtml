<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Reading Platform</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="site-header">
            <div class="brand-bar">
                <a class="brand-logo" asp-controller="Home" asp-action="Index">Reading Platform</a>
            </div>

            <nav class="retro-nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Catalog" asp-action="Index">Catalog</a>
                <a asp-controller="Shelves" asp-action="Index">Shelves</a>
                <a asp-controller="Recommendations" asp-action="Index">Recommendations</a>
                <span class="nav-time">LIBRARY SYSTEM</span>
            </nav>
        </header>

        <main class="main-content">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <span>2026 Reading Platform</span>
        </footer>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>