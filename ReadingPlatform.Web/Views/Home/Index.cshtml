@{
    ViewData["Title"] = "Home";
}

<section class="hero-library">
    <div class="hero-content">
        <p class="eyebrow">A fantasy library for every reader</p>
        <h1>Discover, track, and collect stories worth remembering.</h1>
        <p>
            Build shelves, follow your reading progress, rate books and manga,
            and find your next favorite title through magical recommendations.
        </p>

        <div class="hero-actions">
            <a class="btn btn-gold" asp-controller="Recommendations" asp-action="Index">Open Recommendations</a>
            <a class="btn btn-ghost" asp-controller="Catalog" asp-action="Index">Browse Titles</a>
        </div>
    </div>
</section>

<section class="feature-grid">
    <article>
        <h2>Private Shelves</h2>
        <p>Organize books, manga, and series by your own reading style.</p>
    </article>

    <article>
        <h2>Reading Progress</h2>
        <p>Track volumes, status, ratings, and personal notes.</p>
    </article>

    <article>
        <h2>Magical Discovery</h2>
        <p>Use swipe-style recommendations to quickly find titles you may love.</p>
    </article>
</section>