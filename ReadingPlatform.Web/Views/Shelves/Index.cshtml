@model List<BookTitle>

@{
    ViewData["Title"] = "Shelves";
}

<section class="page-header compact shelf-title-panel">
    <span class="eyebrow">Digital Shelves</span>
    <h1>Your Bookshelf</h1>
</section>

<section class="digital-bookshelf">
    <div class="shelf-row">
        @foreach (var book in Model)
        {
            <button class="shelf-book @book.CoverClass"
                    type="button"
                    data-title="@book.TitleName"
                    data-author="@book.AuthorName"
                    data-format="@book.Format"
                    data-genre="@book.Genre"
                    data-status="@book.ReadingStatus"
                    data-progress="@book.ProgressLabel"
                    data-rating="@book.AverageRating.ToString("0.0")"
                    data-description="@book.Description">  
            </button>
        }
    </div>
</section>

<div class="book-detail-overlay" id="bookDetailOverlay">
    <div class="book-detail-panel" id="bookDetailPanel">
        <button class="close-book" type="button" id="closeBook">X</button>

        <div class="opened-book">
            <div class="opened-book-left">
                <p class="eyebrow">Selected Book</p>
                <h2 id="detailTitle">Book Title</h2>
                <h3 id="detailAuthor">Author</h3>
            </div>

            <div class="opened-book-right">
                <div class="detail-tags">
                    <span id="detailFormat"></span>
                    <span id="detailGenre"></span>
                    <span id="detailStatus"></span>
                    <span id="detailProgress"></span>
                    <span id="detailRating"></span>
                </div>

                <p id="detailDescription"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/shelves.js" asp-append-version="true"></script>
}