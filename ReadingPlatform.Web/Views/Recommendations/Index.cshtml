@model List<BookTitle>
@{
    ViewData["Title"] = "Recommendations";
}

<section class="page-header compact">
    <span class="eyebrow">Recommendations</span>
    <h1>Swipe style discovery concept</h1>
    <p>
        This page presents the recommendation feature. In a future version,
        the cards could support true swipe gestures and user feedback persistence.
    </p>
</section>

<div class="recommendation-stack">
    @foreach (var book in Model)
    {
        <article class="recommendation-card">
            <div class="cover wide @book.CoverClass"></div>
            <div>
                <div class="tag-row">
                    <span class="tag">@book.Format</span>
                    <span class="tag">@book.Genre</span>
                    <span class="tag">@book.AverageRating.ToString("0.0")</span>
                </div>
                <h2>@book.TitleName</h2>
                <p class="muted">by @book.AuthorName</p>
                <p>@book.Description</p>
                <div class="hero-actions">
                    <a class="button button-primary" asp-controller="Catalog" asp-action="Details" asp-route-id="@book.Id">Like</a>
                    <a class="button button-secondary" asp-controller="Catalog" asp-action="Index">Skip</a>
                </div>
            </div>
        </article>
    }
</div>
